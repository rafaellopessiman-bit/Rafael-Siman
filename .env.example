# ── atlas_local — Variáveis de Ambiente ──────────────────────────────────────
# Copie para .env e preencha os valores reais. Nunca commite o .env.

# ── NestJS Application ──────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ── Groq LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# ── MongoDB Atlas Local (docker compose) ────────────────────────────────────
MONGODB_USER=admin
MONGODB_PASSWORD=TROQUE_POR_SENHA_SEGURA
MONGODB_PORT=27017
MONGODB_DB=atlas_local_db

# Usuário da aplicação (criado pelo init script — NÃO use admin em produção)
MONGODB_APP_USER=atlas_app
MONGODB_APP_PASSWORD=TROQUE_POR_OUTRA_SENHA_SEGURA
MONGODB_URI=mongodb://atlas_app:TROQUE_POR_OUTRA_SENHA_SEGURA@localhost:27017/atlas_local_db?authSource=atlas_local_db

# ── Embedding (contrato de schema: numDimensions deve coincidir com o índice vetorial) ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Atlas Search ────────────────────────────────────────────────────────────
ATLAS_VECTOR_SEARCH_ENABLED=false
