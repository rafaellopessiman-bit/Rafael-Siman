# ── atlas_local — Variáveis de Ambiente ──────────────────────────────────────
# Copie para .env e preencha os valores reais. Nunca commite o .env.

# ── NestJS Application ──────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ── Groq LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# ── Python CLI / Indexação Local ────────────────────────────────────────────
DOCUMENTS_PATH=data/entrada
DATABASE_PATH=data/atlas_local.db
TOP_K=5
PDF_OCR_ENABLED=false
PDF_OCR_COMMAND=ocrmypdf
PDF_OCR_LANGUAGE=eng
IMAGE_OCR_ENABLED=false
IMAGE_OCR_COMMAND=tesseract
IMAGE_OCR_LANGUAGE=eng
SCHEDULE_EVAL_QUERIES_PATH=data/eval_queries.json
SCHEDULE_EVAL_BASELINE_PATH=data/eval_baseline.json
SCHEDULE_EVAL_TOP_K=5
SCHEDULE_NOTIFY_WEBHOOK_URL=
SCHEDULE_NOTIFY_TIMEOUT_SECONDS=10
SCHEDULE_NOTIFY_ON=on-issues
SCHEDULE_NOTIFY_FORMAT=raw
WATCH_INTERVAL_SECONDS=30
WATCH_REMEDIATION_POLICY=full-auto
REMEDIATION_ISOLATE_FLAGS=no_usable_chunks,very_short_document,repetitive_content,numeric_heavy,low_vocabulary_document

# ── MongoDB Atlas Local (docker compose) ────────────────────────────────────
MONGODB_USER=admin
MONGODB_PASSWORD=TROQUE_POR_SENHA_SEGURA
MONGODB_PORT=27017
MONGODB_DB=atlas_local_db

# Usuário da aplicação (criado pelo init script — NÃO use admin em produção)
MONGODB_APP_USER=atlas_app
MONGODB_APP_PASSWORD=TROQUE_POR_OUTRA_SENHA_SEGURA
MONGODB_URI=mongodb://atlas_app:TROQUE_POR_OUTRA_SENHA_SEGURA@localhost:27017/atlas_local_db?authSource=atlas_local_db

# ── Redis (BullMQ para indexação assíncrona) ──────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Embedding (contrato de schema: numDimensions deve coincidir com o índice vetorial) ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_API_KEY=cole_sua_chave_embedding_aqui
EMBEDDING_BASE_URL=https://api.openai.com/v1

# ── Atlas Search ────────────────────────────────────────────────────────────
ATLAS_VECTOR_SEARCH_ENABLED=false

# ── Indexação assíncrona ──────────────────────────────────────────────────
INDEX_ASYNC_DRIVER=sync

# ── Cache de respostas ────────────────────────────────────────────────────
CACHE_ASK_TTL_MS=60000

# ── Métricas (Prometheus em /metrics) ─────────────────────────────────────
METRICS_ENABLED=false

# ── Segurança / API ──────────────────────────────────────────────────────
API_KEYS=
CORS_ORIGIN=*

# ── Rate Limiting ────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_ASK_TTL=60000
THROTTLE_ASK_LIMIT=20
THROTTLE_ACT_TTL=60000
THROTTLE_ACT_LIMIT=10
THROTTLE_EXTRACT_TTL=60000
THROTTLE_EXTRACT_LIMIT=30

# ── Health Check ─────────────────────────────────────────────────────────
HEALTH_HEAP_THRESHOLD_MB=512

# ── Python CLI — LLM Cache ───────────────────────────────────────────────
LLM_CACHE_ENABLED=true
LLM_CACHE_MAX_SIZE=256
LLM_CACHE_PERSISTENT=false
LLM_CACHE_PATH=data/llm_cache.json
LLM_CACHE_TTL_SECONDS=3600

# ── Debug ────────────────────────────────────────────────────────────────
ATLAS_DEBUG=false
