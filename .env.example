# ── atlas_local — Variáveis de Ambiente ──────────────────────────────────────
# Copie para .env e preencha os valores reais. Nunca commite o .env.

# ── NestJS Application ──────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ── Groq LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# ── MongoDB Atlas Local (docker compose) ────────────────────────────────────
MONGODB_USER=admin
MONGODB_PASSWORD=AtlasLocal2026!Secure
MONGODB_PORT=27017
MONGODB_URI=mongodb://admin:AtlasLocal2026!Secure@localhost:27017/atlas_local_db?authSource=admin
MONGODB_DB=atlas_local_db

# ── Atlas Search ────────────────────────────────────────────────────────────
ATLAS_VECTOR_SEARCH_ENABLED=false
